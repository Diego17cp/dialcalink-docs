---
import "@/styles/global.css";
import "@fontsource-variable/onest/index.css";
import { ClientRouter } from "astro:transitions";

// TODO: Improve it xd
const {
	title = "DialcaLink - Sync SMS and call events in real time over a local network.",
	description = "Documentation for DialcaLink",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="main-scrollbar">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/dialcalink-logo.svg" />
		<link rel="icon" href="/dialcalink-favicon.ico" />
		<link
			rel="icon"
			type="image/png"
			href="/favicon-96x96.png"
			sizes="96x96"
		/>
		<link rel="shortcut icon" href="/dialcalink-favicon.ico" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<meta name="apple-mobile-web-app-title" content="DialcaLink - Docs" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<ClientRouter />
		<script is:inline>
			function applyTheme() {
				const stored = localStorage.getItem("dialcalink:theme");
				const prefersDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;

				if (stored === "dark" || (!stored && prefersDark))
					document.documentElement.classList.add("dark");
				else document.documentElement.classList.remove("dark");
			}
			applyTheme();
			document.addEventListener("astro:after-swap", applyTheme);
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html {
		scroll-behavior: smooth;
		font-family: "Onest Variable", sans-serif;
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
