---
import { Icon } from "astro-icon/components";
---

<div class="flex lg:hidden items-center space-x-3">
	<button
		id="theme-toggle-mobile"
		class="group relative p-3 rounded-xl bg-linear-to-r from-gray-100 to-gray-200 hover:from-gray-200 hover:to-gray-300 dark:from-gray-800 dark:to-gray-700 dark:hover:from-gray-700 dark:hover:to-gray-600 transition-all duration-200 hover:shadow-lg hover:scale-105 cursor-pointer"
		aria-label="Toggle theme"
		title="Toggle theme"
	>
		<Icon
			name="lucide:sun"
			class="size-5 text-gray-700 dark:text-gray-300 dark:hidden"
		/>
		<Icon
			name="lucide:moon"
			class="size-5 text-yellow-500 hidden dark:block"
		/>
	</button>
	<button
		id="mobile-menu-toggle"
		class="flex-lg:hidden group relative p-3 rounded-xl bg-linear-to-r from-gray-100 to-gray-200 hover:from-gray-200 hover:to-gray-300 dark:from-gray-800 dark:to-gray-700 dark:hover:from-gray-700 dark:hover:to-gray-600 transition-all duration-200 hover:shadow-lg hover:scale-105 cursor-pointer"
		aria-label="Toggle menu"
		title="Toggle menu"
	>
		<Icon
			name="lucide:menu"
			class="size-6 text-gray-700 dark:text-gray-300 transition-transform duration-200 menu-btn"
		/>
		<Icon
			name="lucide:x"
			class="size-6 text-gray-700 dark:text-gray-300 transition-transform duration-200 close-btn hidden"
		/>
	</button>
</div>
